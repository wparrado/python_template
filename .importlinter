[importlinter]
root_packages =
    app

[importlinter:contract:domain-independence]
name = Domain has no outward dependencies
type = forbidden
source_modules =
    app.domain
forbidden_modules =
    app.application
    app.infrastructure
    app.presentation

[importlinter:contract:application-independence]
name = Application does not depend on infrastructure or presentation
type = forbidden
source_modules =
    app.application
forbidden_modules =
    app.infrastructure
    app.presentation

[importlinter:contract:presentation-independence]
name = Presentation does not depend on infrastructure
type = forbidden
source_modules =
    app.presentation
forbidden_modules =
    app.infrastructure
