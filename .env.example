# Copy to .env and fill in your values
APP_NAME=app
DEBUG=false
LOG_LEVEL=INFO

# Authentication — Generic OIDC (works with Keycloak, Auth0, Cognito, Google, etc.)
# Leave empty to disable authentication (dev only)
OIDC_ISSUER=
OIDC_AUDIENCE=

# OpenTelemetry — set OTEL_ENABLED=true and point to your OTLP backend
OTEL_ENABLED=false
OTEL_SERVICE_NAME=app
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Persistence backend: 'memory' (default, no DB) or 'sqlalchemy'
DB_BACKEND=memory
DATABASE_URL=postgresql+asyncpg://app:app@localhost/app

# Transactional Outbox poll interval (seconds, only used when DB_BACKEND=sqlalchemy)
OUTBOX_POLL_INTERVAL_SECONDS=1.0

# Event broker: 'memory' (default, in-process) | 'rabbitmq' | 'kafka'
EVENT_BROKER=memory

# RabbitMQ — required when EVENT_BROKER=rabbitmq
RABBITMQ_URL=amqp://guest:guest@localhost/
RABBITMQ_EXCHANGE=domain.events

# Kafka — required when EVENT_BROKER=kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PREFIX=app
